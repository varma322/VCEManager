<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_container_snapshots.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSnapshot"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="📸  Save Snapshot Now"
        android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/emptySnapshots"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="No snapshots yet.\nTap 'Save Snapshot' to capture the current state."
        android:gravity="center" android:padding="32dp"
        android:textColor="?attr/colorOnSurfaceVariant" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSnapshots"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
