<?xml version="1.0" encoding="utf-8"?>
<!-- item_container_mini.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:padding="12dp" android:background="?attr/selectableItemBackground">

    <View android:id="@+id/statusDot"
        android:layout_width="8dp" android:layout_height="8dp"
        android:background="@drawable/dot_red" android:layout_marginEnd="12dp"/>

    <TextView android:id="@+id/tvName"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textStyle="bold"/>

    <TextView android:id="@+id/tvIp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="12sp" android:textColor="?attr/colorOnSurfaceVariant"/>
</LinearLayout>
